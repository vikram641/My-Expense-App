<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Expense" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Background -->
        <item name="android:windowBackground">@color/bg_card</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
<!--        <item name="android:navigationBarColor">@android:color/transparent</item>-->




        <!-- Primary Colors -->
        <item name="colorPrimary">@color/bg_card</item>
        <item name="colorSecondary">@color/green</item>
        <item name="android:fontFamily">@font/poppins</item>
        <item name="fontFamily">@font/poppins</item>


<!--        &lt;!&ndash; Status bar &ndash;&gt;-->
<!--        <item name="android:statusBarColor">@color/accent</item>-->


    </style>

    <style name="Theme.Expense" parent="Base.Theme.Expense" />
    <style name="TextAppearance.BudgetTracker.ChartLegend" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_primary</item>

        <!-- Apply font everywhere -->
        <item name="android:fontFamily">@font/poppins</item>
        <item name="fontFamily">@font/poppins</item>
<!--        &lt;!&ndash;add current &ndash;&gt;-->
<!--        <item name="android:windowFullscreen">true</item>-->
<!--        <item name="android:windowContentOverlay">@null</item>-->
    </style>

    <style name="ChipStyle">
        <item name="android:padding">10dp</item>
        <item name="android:background">@drawable/bg_chip</item>
        <item name="android:textColor">#A0A0A0</item>
        <item name="android:layout_marginEnd">8dp</item>
    </style>

    <style name="ChipStyleSelected">
        <item name="android:padding">10dp</item>
        <item name="android:background">@drawable/bg_chip_selected</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:layout_marginEnd">8dp</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">

        <!-- ✅ Full purple — nothing else -->
        <item name="windowSplashScreenBackground">@color/accent</item>

        <!-- ✅ Transparent icon — nothing visible -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_transparent</item>

        <!-- ✅ No icon background -->
        <item name="windowSplashScreenIconBackgroundColor">#00000000</item>

        <!-- ✅ Zero duration -->
        <item name="windowSplashScreenAnimationDuration">0</item>

        <item name="postSplashScreenTheme">@style/Theme.Expense</item>

    </style>




</resources>